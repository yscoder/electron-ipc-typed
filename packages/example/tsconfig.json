{
    "compilerOptions": {
        "baseUrl": ".",
        "lib": [
            "esnext",
            "dom"
        ],
        "target": "ESNext",
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
    },
    "include": [
        "src",
    ]
}